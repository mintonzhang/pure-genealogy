# ============================================
# pure-genealogy 环境变量模板
# 复制此文件为 .env 并修改配置
# ============================================

# 家族姓氏（本地开发和 Docker 部署通用）
# 注意：NEXT_PUBLIC_* 变量在构建时内联到客户端代码，Docker 部署时通过 FAMILY_SURNAME 间接传入
NEXT_PUBLIC_FAMILY_SURNAME=张

# JWT 密钥（生产环境务必更换为随机字符串）
# 生成方式: openssl rand -base64 32
JWT_SECRET=

# 管理员账号（Docker 容器启动时自动创建，已存在则跳过）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# 登录表单预填充（可选，方便开发调试）
NEXT_PUBLIC_LOGIN_USERNAME=
NEXT_PUBLIC_LOGIN_PASSWORD=

# 数据库文件路径（默认 data/family.db，Docker 部署通常不需修改）
DB_PATH=
